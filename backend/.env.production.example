# Production Environment
DATABASE_URL="postgresql://postgres:replace-with-strong-password@localhost:5432/jaecoo_service_system"
PORT=3000
NODE_ENV=production
JWT_SECRET="replace-with-very-strong-random-secret"
JWT_EXPIRES_IN=8h
FRONTEND_URL="https://your-frontend-domain.com"
BCRYPT_ROUNDS=12

# Security hardening
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=20
CSP="default-src 'self'"
