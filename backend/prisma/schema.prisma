generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // url      = env("DATABASE_URL")
}

enum StatusServis {
  ANTRIAN
  DIKERJAKAN
  TEST_DRIVE
  SELESAI
  DIAMBIL
  TERKENDALA
}

enum Role {
  MEKANIK
  FRONTLINE
  MANAGER
  ADMIN
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  CANCELLED
}

enum PriorityLevel {
  NORMAL
  HIGH
  URGENT
}

model User {
  id_user   Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdWorkOrders WorkOrder[] @relation("WorkOrderCreatedBy")
}

model Pemilik {
  nik       String   @id
  nama      String
  no_hp     String?
  alamat    String?
  createdAt DateTime @default(now())

  kendaraan Kendaraan[]
}

model Kendaraan {
  no_rangka   String   @id
  plat_nomor  String   @unique
  jenis_mobil String?
  warna       String?
  tahun       Int?
  kilometer   Int      @default(0)
  createdAt   DateTime @default(now())

  nik_pemilik String
  pemilik     Pemilik @relation(fields: [nik_pemilik], references: [nik])

  work_orders WorkOrder[]
}

model WorkOrder {
  id_wo           Int             @id @default(autoincrement())
  nomor_wo_pusat  String?
  waktuMasuk      DateTime        @default(now())
  status          WorkOrderStatus @default(OPEN)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  no_rangka       String
  kendaraan       Kendaraan @relation(fields: [no_rangka], references: [no_rangka])

  created_by_user_id Int?
  createdBy        User?     @relation("WorkOrderCreatedBy", fields: [created_by_user_id], references: [id_user])

  servis Servis[]
}

model Servis {
  id_servis       Int           @id @default(autoincrement())
  keluhan         String
  estimasiSelesai DateTime?
  tanggalSelesai  DateTime?
  status          StatusServis  @default(ANTRIAN)
  prioritas       PriorityLevel @default(NORMAL)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  id_wo     Int
  workOrder WorkOrder @relation(fields: [id_wo], references: [id_wo])

  detail_servis DetailServis[]
  catatan       CatatanMekanik[]
  riwayat       RiwayatServis[]
}

model JenisServis {
  id_jenis_servis Int    @id @default(autoincrement())
  nama_servis     String @unique
  createdAt       DateTime @default(now())

  detail_servis DetailServis[]
}

model DetailServis {
  id_detail Int @id @default(autoincrement())

  id_servis Int
  servis    Servis @relation(fields: [id_servis], references: [id_servis])

  id_jenis_servis Int
  jenis_servis    JenisServis @relation(fields: [id_jenis_servis], references: [id_jenis_servis])

  keterangan String?
}

model CatatanMekanik {
  id_catatan Int @id @default(autoincrement())

  id_servis Int
  servis    Servis @relation(fields: [id_servis], references: [id_servis])

  catatan String
  waktu   DateTime @default(now())
}

model RiwayatServis {
  id_riwayat Int @id @default(autoincrement())

  id_servis Int
  servis    Servis @relation(fields: [id_servis], references: [id_servis])

  status StatusServis
  waktu  DateTime @default(now())
}
